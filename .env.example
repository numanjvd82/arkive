# Local dev from host:
# DATABASE_URL=postgres://devuser:devpassword123!@localhost:5132/arkive_dev?sslmode=disable
# Docker Compose app container:
# DATABASE_URL=postgres://devuser:devpassword123!@db:5432/arkive_dev?sslmode=disable
DATABASE_URL=postgres://devuser:devpassword123!@localhost:5132/arkive_dev?sslmode=disable
COOKIE_SECRET=change-me
SESSION_TTL=6h
PASSWORD_RESET_TOKEN_TTL=30m
# For dev, Core defaults BASE_URL if APP_ENV=dev.
# For VPS or any public deploy, set APP_ENV=prod and BASE_URL=https://your-domain.com.
APP_ENV=dev
# BASE_URL=http://localhost:8080
